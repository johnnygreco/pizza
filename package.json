{
  "name": "pizza",
  "version": "0.1.0",
  "description": "\uD83C\uDF55 Pizza \u2014 Pi with toppings",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "pizza": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && chmod +x dist/cli.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.66.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
